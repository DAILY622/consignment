{% extends 'base.html' %}
{% load static %}

{% block title %}DailyFX Delivery - UK Parcel Delivery & Tracking{% endblock %}

{% block extra_head %}
<style>
    .hero-bg {
        background: linear-gradient(135deg, rgba(249, 115, 22, 0.95) 0%, rgba(234, 88, 12, 0.95) 100%),
                    url('https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=1920&q=80') center/cover;
    }
    .testimonial-slider { animation: slide 20s infinite; }
    @keyframes slide { 0%, 30% { transform: translateX(0); } 35%, 65% { transform: translateX(-100%); } 70%, 100% { transform: translateX(-200%); } }
    .partner-logo { filter: grayscale(100%) brightness(0.6); transition: all 0.3s; }
    .partner-logo:hover { filter: grayscale(0%) brightness(1); }
    @keyframes scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
    .animate-scroll { display: flex; animation: scroll 20s linear infinite; }
    .animate-scroll:hover { animation-play-state: paused; }
    @keyframes progress { 0% { width: 60%; } 100% { width: 70%; } }
    /* Popup Review Styles */
    .popup-review {
        animation: slideInUp 0.5s ease-out, fadeOut 0.5s ease-in 4.5s forwards;
    }
    @keyframes slideInUp {
        from { transform: translateY(100px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    @keyframes fadeOut {
        to { opacity: 0; transform: translateY(-20px); }
    }
</style>
{% endblock %}

{% block content %}
<!-- Hero Section with Real Background -->
<div class="hero-bg rounded-2xl text-white p-12 mb-12 relative overflow-hidden min-h-[500px] flex items-center">
    <div class="absolute inset-0 bg-gradient-to-r from-orange-900/80 to-amber-900/60"></div>
    <div class="grid md:grid-cols-2 gap-8 items-center relative z-10 w-full">
        <div>
            <span class="bg-white/20 backdrop-blur text-sm px-4 py-2 rounded-full mb-4 inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                #1 Rated UK Delivery Service
            </span>
            <h1 class="text-5xl font-bold mb-4 leading-tight">Fast, Reliable Parcel Delivery Across the UK</h1>
            <p class="text-xl text-orange-100 mb-8">Track your packages in real-time with GPS. Same-day, next-day, and standard delivery options available.</p>
            <div class="flex flex-wrap gap-4">
                <a href="{% url 'track' %}" class="bg-white text-orange-600 px-8 py-3 rounded-lg font-semibold hover:bg-orange-100 transition shadow-lg flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    Track Package
                </a>
                {% if not user.is_authenticated %}
                    <a href="{% url 'register' %}" class="border-2 border-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-orange-600 transition">Get Started Free</a>
                {% else %}
                    <a href="{% url 'create_package' %}" class="border-2 border-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-orange-600 transition">+ Send Package</a>
                {% endif %}
                <a href="#quote" class="bg-orange-500 px-8 py-3 rounded-lg font-semibold hover:bg-orange-400 transition flex items-center gap-2">
                    💷 Get a Quote
                </a>
            </div>
            <!-- Trust Indicators with Real Photos -->
            <div class="flex items-center gap-6 mt-8 pt-6 border-t border-white/20">
                <div class="flex -space-x-3">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&h=80&fit=crop&crop=face" class="w-10 h-10 rounded-full border-2 border-white object-cover" alt="Customer">
                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop&crop=face" class="w-10 h-10 rounded-full border-2 border-white object-cover" alt="Customer">
                    <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=80&h=80&fit=crop&crop=face" class="w-10 h-10 rounded-full border-2 border-white object-cover" alt="Customer">
                    <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=80&h=80&fit=crop&crop=face" class="w-10 h-10 rounded-full border-2 border-white object-cover" alt="Customer">
                </div>
                <div>
                    <div class="flex text-yellow-400 text-sm">★★★★★</div>
                    <p class="text-sm text-orange-200">Trusted by 50,000+ customers</p>
                </div>
            </div>
        </div>
        <div class="hidden md:block">
            <img src="https://images.unsplash.com/photo-1616432043562-3671ea2e5242?w=600&h=500&fit=crop" alt="Delivery Driver" class="rounded-2xl shadow-2xl transform rotate-2 hover:rotate-0 transition-transform duration-500 object-cover">
        </div>
    </div>
</div>

<!-- Quick Track -->
<div class="bg-gradient-to-r from-primary-50 to-accent-50 rounded-xl shadow-lg p-8 mb-12 border border-primary-100">
    <h2 class="text-2xl font-bold text-primary-800 mb-4 flex items-center gap-3">
        <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        Quick Track
    </h2>
    <form action="{% url 'track' %}" method="GET" class="flex flex-col md:flex-row gap-4">
        <input type="text" name="q" placeholder="Enter tracking number (e.g., DFX-XXXXXXXX)" 
               class="flex-1 px-4 py-3 border border-primary-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent bg-white">
        <button type="submit" class="bg-primary-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-primary-700 transition">
            Track Now
        </button>
    </form>
</div>

<!-- Trust Badges with Real Icons -->
<div class="bg-white rounded-xl p-6 mb-12 shadow-lg border border-gray-100">
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
        <div class="flex items-center gap-3">
            <img src="{% static 'icons/icons8-color-48-ssl-security.svg' %}" alt="SSL" class="w-10 h-10">
            <span class="font-semibold text-gray-700">SSL Secured</span>
        </div>
        <div class="flex items-center gap-3">
            <img src="{% static 'icons/icons8-color-48-checkmark--v1.svg' %}" alt="GDPR" class="w-10 h-10">
            <span class="font-semibold text-gray-700">GDPR Compliant</span>
        </div>
        <div class="flex items-center gap-3">
            <img src="{% static 'icons/icons8-color-48-shield--v1.svg' %}" alt="Insured" class="w-10 h-10">
            <span class="font-semibold text-gray-700">Insured Delivery</span>
        </div>
        <div class="flex items-center gap-3">
            <img src="{% static 'icons/icons8-color-48-star--v1.svg' %}" alt="Rating" class="w-10 h-10">
            <span class="font-semibold text-gray-700">4.9/5 Rating</span>
        </div>
        <div class="flex items-center gap-3">
            <img src="{% static 'icons/icons8-color-48-prize.svg' %}" alt="ISO" class="w-10 h-10">
            <span class="font-semibold text-gray-700">ISO Certified</span>
        </div>
    </div>
</div>

<!-- Trusted By Section -->
<div class="mb-12">
    <p class="text-center text-gray-500 mb-6 text-sm uppercase tracking-wider">Trusted by leading UK businesses</p>
    <div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-60">
        <img src="{% static 'icons/icons8-color-96-amazon.svg' %}" alt="Amazon" class="h-8 partner-logo">
        <img src="{% static 'icons/icons8-color-96-ebay.svg' %}" alt="eBay" class="h-8 partner-logo">
        <img src="{% static 'icons/icons8-fluency-96-shopify.svg' %}" alt="Shopify" class="h-8 partner-logo">
        <img src="{% static 'icons/icons8-color-96-etsy.svg' %}" alt="Etsy" class="h-8 partner-logo">
        <img src="{% static 'icons/icons8-color-96-woocommerce.svg' %}" alt="WooCommerce" class="h-8 partner-logo">
    </div>
</div>

<!-- How It Works with Real Images -->
<div class="mb-16">
    <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-800 mb-2">How It Works</h2>
        <p class="text-gray-600">Send your parcels in 3 simple steps</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
        <div class="relative">
            <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100">
                <img src="https://images.unsplash.com/photo-1586281380349-632531db7ed4?w=400&h=250&fit=crop" alt="Person booking delivery online" class="w-full h-48 object-cover">
                <div class="p-6 text-center">
                    <div class="absolute top-4 left-4 w-10 h-10 bg-orange-600 text-white rounded-full flex items-center justify-center font-bold text-lg shadow-lg">1</div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Book Online</h3>
                    <p class="text-gray-600">Enter pickup & delivery details. Get instant pricing and choose your delivery speed.</p>
                </div>
            </div>
        </div>
        <div class="relative">
            <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100">
                <img src="https://images.unsplash.com/photo-1566576912321-d58ddd7a6088?w=400&h=250&fit=crop" alt="Delivery driver collecting package" class="w-full h-48 object-cover">
                <div class="p-6 text-center">
                    <div class="absolute top-4 left-4 w-10 h-10 bg-orange-600 text-white rounded-full flex items-center justify-center font-bold text-lg shadow-lg">2</div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">We Collect</h3>
                    <p class="text-gray-600">Our driver picks up your parcel from your door. Track every step in real-time.</p>
                </div>
            </div>
        </div>
        <div class="relative">
            <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100">
                <img src="https://images.unsplash.com/photo-1580674285054-bed31e145f59?w=400&h=250&fit=crop" alt="Happy customer receiving package" class="w-full h-48 object-cover">
                <div class="p-6 text-center">
                    <div class="absolute top-4 left-4 w-10 h-10 bg-orange-600 text-white rounded-full flex items-center justify-center font-bold text-lg shadow-lg">3</div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Delivered</h3>
                    <p class="text-gray-600">Package delivered with photo proof & signature. You'll get instant confirmation.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Services & Pricing -->
<div class="mb-16" id="services">
    <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-800 mb-2">Our Services</h2>
        <p class="text-gray-600">Choose the delivery speed that suits your needs</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
        <!-- Standard -->
        <div class="bg-gradient-to-br from-primary-50 to-accent-50 rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border-2 border-transparent hover:border-primary-200">
            <div class="bg-primary-100 p-6 text-center">
                <span class="text-4xl">📦</span>
                <h3 class="text-2xl font-bold text-primary-800 mt-2">Standard</h3>
                <p class="text-primary-600">2-3 Business Days</p>
            </div>
            <div class="p-6 bg-white/50">
                <div class="text-center mb-6">
                    <span class="text-4xl font-bold text-primary-800">£{{ site_settings.price_standard }}</span>
                    <span class="text-primary-600">/parcel</span>
                </div>
                <ul class="space-y-3 mb-6">
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> Up to 20kg</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> GPS Tracking</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> Email Updates</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> £{{ site_settings.coverage_standard|floatformat:0 }} Cover Included</li>
                </ul>
                <a href="{% url 'register' %}" class="block text-center bg-primary-700 text-white py-3 rounded-lg font-semibold hover:bg-primary-800 transition">Select Standard</a>
            </div>
        </div>
        
        <!-- Express - Featured -->
        <div class="bg-gradient-to-br from-primary-100 to-accent-100 rounded-xl shadow-xl overflow-hidden border-2 border-primary-500 transform md:-translate-y-4">
            <div class="bg-gradient-to-r from-primary-600 to-accent-600 text-white p-6 text-center relative">
                <span class="absolute top-2 right-2 bg-yellow-400 text-yellow-900 text-xs px-2 py-1 rounded-full font-bold">POPULAR</span>
                <span class="text-4xl">🚀</span>
                <h3 class="text-2xl font-bold mt-2">Express</h3>
                <p class="text-primary-200">Next Business Day</p>
            </div>
            <div class="p-6 bg-white/70">
                <div class="text-center mb-6">
                    <span class="text-4xl font-bold text-primary-800">£{{ site_settings.price_next_day }}</span>
                    <span class="text-primary-600">/parcel</span>
                </div>
                <ul class="space-y-3 mb-6">
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> Up to 30kg</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> Live GPS Tracking</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> SMS + Email Updates</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> £{{ site_settings.coverage_next_day|floatformat:0 }} Cover Included</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> Priority Handling</li>
                </ul>
                <a href="{% url 'register' %}" class="block text-center bg-gradient-to-r from-primary-600 to-accent-600 text-white py-3 rounded-lg font-semibold hover:from-primary-700 hover:to-accent-700 transition">Select Express</a>
            </div>
        </div>
        
        <!-- Same Day -->
        <div class="bg-gradient-to-br from-accent-50 to-primary-50 rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border-2 border-transparent hover:border-accent-200">
            <div class="bg-gradient-to-r from-accent-500 to-pink-500 text-white p-6 text-center">
                <span class="text-4xl">⚡</span>
                <h3 class="text-2xl font-bold mt-2">Same Day</h3>
                <p class="text-accent-200">Delivered Today</p>
            </div>
            <div class="p-6 bg-white/50">
                <div class="text-center mb-6">
                    <span class="text-4xl font-bold text-primary-800">£{{ site_settings.price_same_day }}</span>
                    <span class="text-primary-600">/parcel</span>
                </div>
                <ul class="space-y-3 mb-6">
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> Up to 30kg</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> Real-Time Tracking</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> Instant Notifications</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> £200 Cover Included</li>
                    <li class="flex items-center text-primary-700"><span class="text-green-500 mr-2">✓</span> Dedicated Driver</li>
                </ul>
                <a href="{% url 'register' %}" class="block text-center bg-accent-600 text-white py-3 rounded-lg font-semibold hover:bg-accent-700 transition">Select Same Day</a>
            </div>
        </div>
    </div>
</div>

<!-- Quote Calculator -->
<div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-2xl p-8 mb-16" id="quote">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-white mb-2">💷 Get an Instant Quote</h2>
            <p class="text-indigo-200">Calculate your shipping cost in seconds</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-xl">
            <div class="grid md:grid-cols-4 gap-4 mb-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">From (Postcode)</label>
                    <input type="text" id="quote-from" placeholder="e.g., SW1A 1AA" 
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">To (Postcode)</label>
                    <input type="text" id="quote-to" placeholder="e.g., M1 1AD" 
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Weight (kg)</label>
                    <input type="number" id="quote-weight" placeholder="e.g., 5" min="0.1" step="0.1"
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Service</label>
                    <select id="quote-service" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500">
                        <option value="standard">Standard (2-3 days)</option>
                        <option value="express" selected>Express (Next day)</option>
                        <option value="sameday">Same Day</option>
                    </select>
                </div>
            </div>
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <button onclick="calculateQuote()" class="w-full md:w-auto bg-indigo-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition">
                    Calculate Price
                </button>
                <div id="quote-result" class="text-center md:text-right">
                    <p class="text-sm text-gray-500">Estimated Price</p>
                    <p class="text-3xl font-bold text-indigo-600">£--</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features with Real Images -->
<div class="grid md:grid-cols-3 gap-8 mb-16">
    <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100 group">
        <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=400&h=200&fit=crop" alt="GPS tracking dashboard" class="w-full h-40 object-cover">
        <div class="p-6 text-center">
            <h3 class="text-xl font-bold text-gray-800 mb-2">Real-Time GPS Tracking</h3>
            <p class="text-gray-600">Know exactly where your package is at any moment with live map updates and notifications.</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100 group">
        <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=400&h=200&fit=crop" alt="UK city skyline" class="w-full h-40 object-cover">
        <div class="p-6 text-center">
            <h3 class="text-xl font-bold text-gray-800 mb-2">UK-Wide Coverage</h3>
            <p class="text-gray-600">From London to Edinburgh, we deliver to every corner of the United Kingdom, including remote areas.</p>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition border border-gray-100 group">
        <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=400&h=200&fit=crop" alt="Delivery confirmation signature" class="w-full h-40 object-cover">
        <div class="p-6 text-center">
            <h3 class="text-xl font-bold text-gray-800 mb-2">Proof of Delivery</h3>
            <p class="text-gray-600">Photos and digital signatures captured on delivery for your complete peace of mind.</p>
        </div>
    </div>
</div>

<!-- Stats with Background Image -->
<div class="relative rounded-xl text-white p-8 mb-16 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-gray-900/95 to-gray-800/90"></div>
    <img src="https://images.unsplash.com/photo-1553413077-190dd305871c?w=1920&h=400&fit=crop" alt="Warehouse" class="absolute inset-0 w-full h-full object-cover -z-10">
    <div class="grid md:grid-cols-4 gap-8 text-center relative z-10">
        <div>
            <div class="text-4xl font-bold text-orange-400">50K+</div>
            <div class="text-gray-300">Packages Delivered</div>
        </div>
        <div>
            <div class="text-4xl font-bold text-green-400">99.2%</div>
            <div class="text-gray-300">On-Time Delivery</div>
        </div>
        <div>
            <div class="text-4xl font-bold text-purple-400">500+</div>
            <div class="text-gray-300">Active Drivers</div>
        </div>
        <div>
            <div class="text-4xl font-bold text-yellow-400">24/7</div>
            <div class="text-gray-300">Customer Support</div>
        </div>
    </div>
</div>

<!-- Testimonials with Real Photos -->
<div class="mb-16">
    <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-primary-800 mb-2">What Our Customers Say</h2>
        <p class="text-primary-600">Trusted by thousands of businesses and individuals across the UK</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition border border-gray-100 relative">
            <div class="absolute -top-4 left-6 text-5xl text-indigo-200">"</div>
            <div class="flex items-center mb-4 relative z-10">
                <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop&crop=face" alt="James Davidson" class="w-14 h-14 rounded-full border-4 border-indigo-100 mr-4 object-cover">
                <div>
                    <p class="font-semibold text-gray-800">James Davidson</p>
                    <p class="text-sm text-gray-500">E-commerce Owner, London</p>
                </div>
            </div>
            <div class="flex text-yellow-400 mb-3">★★★★★</div>
            <p class="text-gray-600">"DailyFX Delivery has transformed our shipping. Real-time tracking keeps our customers happy, and the same-day option is a game-changer for urgent orders."</p>

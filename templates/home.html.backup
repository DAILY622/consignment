                <span class="text-xs text-gray-500">15 min ago</span>
            </div>
            <div class="flex items-center gap-3 bg-blue-50 px-4 py-2 rounded-lg whitespace-nowrap">
                <span class="w-2 h-2 bg-blue-500 rounded-full"></span>
                <span class="text-sm">In transit to <strong>Glasgow</strong></span>
                <span class="text-xs text-gray-500">18 min ago</span>
            </div>
        </div>
    </div>
</div>

<!-- FAQ Section -->
<div class="mb-16" id="faq">
    <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-primary-800 mb-2">Frequently Asked Questions</h2>
        <p class="text-primary-600">Got questions? We've got answers</p>
    </div>
    <div class="max-w-3xl mx-auto space-y-4">
        <div class="bg-gradient-to-r from-primary-50 to-accent-50 rounded-xl shadow border border-primary-100">
            <button onclick="toggleFaq(this)" class="w-full px-6 py-4 text-left flex justify-between items-center">
                <span class="font-semibold text-primary-800">How do I track my package?</span>
                <span class="text-primary-600 transform transition-transform">▼</span>
            </button>
            <div class="px-6 pb-4 hidden faq-content">
                <p class="text-primary-700">Simply enter your tracking number (e.g., DFX-XXXXXXXX) in the tracking box on our homepage or tracking page. You'll see real-time updates including GPS location, status changes, and estimated delivery time.</p>
            </div>
        </div>
        <div class="bg-gradient-to-r from-primary-50 to-accent-50 rounded-xl shadow border border-primary-100">
            <button onclick="toggleFaq(this)" class="w-full px-6 py-4 text-left flex justify-between items-center">
                <span class="font-semibold text-primary-800">What are your delivery times?</span>
                <span class="text-primary-600 transform transition-transform">▼</span>
            </button>
            <div class="px-6 pb-4 hidden faq-content">
                <p class="text-primary-700">We offer three service levels: <strong>Standard</strong> (2-3 business days), <strong>Express</strong> (next business day), and <strong>Same Day</strong> (delivered within hours, subject to booking time and location).</p>
            </div>
        </div>
        <div class="bg-gradient-to-r from-primary-50 to-accent-50 rounded-xl shadow border border-primary-100">
            <button onclick="toggleFaq(this)" class="w-full px-6 py-4 text-left flex justify-between items-center">
                <span class="font-semibold text-primary-800">What's the maximum weight you accept?</span>
                <span class="text-primary-600 transform transition-transform">▼</span>
            </button>
            <div class="px-6 pb-4 hidden faq-content">
                <p class="text-primary-700">Standard service accepts up to 20kg, while Express and Same Day services accept up to 30kg per parcel. For heavier items, please contact our business team for custom solutions.</p>
            </div>
        </div>
        <div class="bg-gradient-to-r from-primary-50 to-accent-50 rounded-xl shadow border border-primary-100">
            <button onclick="toggleFaq(this)" class="w-full px-6 py-4 text-left flex justify-between items-center">
                <span class="font-semibold text-primary-800">Are my parcels insured?</span>
                <span class="text-primary-600 transform transition-transform">▼</span>
            </button>
            <div class="px-6 pb-4 hidden faq-content">
                <p class="text-primary-700">Yes! All shipments include insurance cover: Standard (£50), Express (£100), and Same Day (£200). Additional cover up to £1,000 can be purchased at checkout for valuable items.</p>
            </div>
        </div>
        <div class="bg-gradient-to-r from-primary-50 to-accent-50 rounded-xl shadow border border-primary-100">
            <button onclick="toggleFaq(this)" class="w-full px-6 py-4 text-left flex justify-between items-center">
                <span class="font-semibold text-primary-800">Can I change the delivery address?</span>
                <span class="text-primary-600 transform transition-transform">▼</span>
            </button>
            <div class="px-6 pb-4 hidden faq-content">
                <p class="text-primary-700">Yes, you can redirect your parcel before it goes out for delivery. Log into your account, go to your dashboard, and select the package to modify. Redirection fees may apply.</p>
            </div>
        </div>
    </div>
</div>

<!-- Newsletter Section -->
<div class="bg-gradient-to-r from-primary-100 to-accent-100 rounded-2xl p-8 md:p-12 mb-16 border border-primary-200">
    <div class="max-w-2xl mx-auto text-center">
        <span class="text-4xl mb-4 block">📧</span>
        <h2 class="text-3xl font-bold text-primary-800 mb-2">Stay Updated</h2>
        <p class="text-primary-600 mb-6">Subscribe to our newsletter for exclusive deals, shipping tips, and service updates.</p>
        <form method="post" action="{% url 'home' %}" class="flex flex-col sm:flex-row gap-4 justify-center">
            {% csrf_token %}
            <input type="email" name="newsletter_email" placeholder="Enter your email address" 
                   class="flex-1 max-w-md px-4 py-3 border border-primary-200 rounded-lg focus:ring-2 focus:ring-primary-500 bg-white">
            <button type="submit" class="bg-gradient-to-r from-primary-600 to-accent-600 text-white px-8 py-3 rounded-lg font-semibold hover:from-primary-700 hover:to-accent-700 transition">
                Subscribe
            </button>
        </form>
        <p class="text-xs text-primary-500 mt-4">By subscribing, you agree to our Privacy Policy. Unsubscribe anytime.</p>
    </div>
</div>

<!-- Final CTA -->
<div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-2xl p-8 md:p-12 text-white text-center mb-8">
    <h2 class="text-3xl font-bold mb-4">Ready to Ship?</h2>
    <p class="text-xl text-indigo-100 mb-8 max-w-2xl mx-auto">Join thousands of happy customers. Send your first parcel today and experience the DailyFX Delivery difference.</p>
    <div class="flex flex-wrap justify-center gap-4">
        {% if not user.is_authenticated %}
            <a href="{% url 'register' %}" class="bg-white text-indigo-600 px-8 py-3 rounded-lg font-semibold hover:bg-indigo-100 transition shadow-lg">Create Free Account</a>
        {% else %}
            <a href="{% url 'create_package' %}" class="bg-white text-indigo-600 px-8 py-3 rounded-lg font-semibold hover:bg-indigo-100 transition shadow-lg">+ Send a Package</a>
        {% endif %}
        <a href="{% url 'track' %}" class="border-2 border-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-indigo-600 transition">Track Package</a>
    </div>
</div>
{% endblock %}

{% block extra_js %}
<script>
// FAQ Toggle - initialise arrow state to match hidden class on page load
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.faq-content').forEach(function(content) {
        const arrow = content.previousElementSibling.querySelector('span:last-child');
        if (arrow) {
            arrow.style.transform = content.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
        }
    });
});

function toggleFaq(button) {
    const content = button.nextElementSibling;
    const arrow = button.querySelector('span:last-child');
    content.classList.toggle('hidden');
    arrow.style.transform = content.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
}

// Quote Calculator
function calculateQuote() {
    const from = document.getElementById('quote-from').value;
    const to = document.getElementById('quote-to').value;
    const weight = parseFloat(document.getElementById('quote-weight').value) || 0;
    const service = document.getElementById('quote-service').value;
    
    if (!from || !to || weight <= 0) {
        alert('Please fill in all fields');
        return;
    }
    
    // Base prices
    let basePrice = {
        'standard': 4.99,
        'express': 8.99,
        'sameday': 14.99
    }[service];
    
    // Weight surcharge (£0.50 per kg over 5kg)
    let weightSurcharge = weight > 5 ? (weight - 5) * 0.50 : 0;
    
    // Calculate total
    let total = basePrice + weightSurcharge;
    
    // Display result
    document.getElementById('quote-result').innerHTML = `
        <p class="text-sm text-gray-500">Estimated Price</p>
        <p class="text-3xl font-bold text-orange-600">£${total.toFixed(2)}</p>
        <p class="text-xs text-gray-400">${weight}kg via ${service}</p>
    `;
}

// Popup Review System
const reviews = [
    { name: 'Emma Wilson', location: 'London', rating: 5, text: 'Package arrived same day! Amazing service.', img: 'https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=60&h=60&fit=crop&crop=face', time: '2 minutes ago' },
    { name: 'David Chen', location: 'Manchester', rating: 5, text: 'Best tracking system I\'ve ever used.', img: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=60&h=60&fit=crop&crop=face', time: '5 minutes ago' },
    { name: 'Sophie Taylor', location: 'Birmingham', rating: 5, text: 'My business relies on DailyFX. Never late!', img: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=60&h=60&fit=crop&crop=face', time: '8 minutes ago' },
    { name: 'James Brown', location: 'Leeds', rating: 5, text: 'Driver was so professional and friendly.', img: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=60&h=60&fit=crop&crop=face', time: '12 minutes ago' },
    { name: 'Priya Sharma', location: 'Glasgow', rating: 5, text: 'GPS tracking is incredibly accurate!', img: 'https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=60&h=60&fit=crop&crop=face', time: '15 minutes ago' },
    { name: 'Tom Richards', location: 'Edinburgh', rating: 5, text: 'Switched from Royal Mail. Much better!', img: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=60&h=60&fit=crop&crop=face', time: '18 minutes ago' }
];

// Create popup container and append to body
let popupContainer = document.createElement('div');
popupContainer.id = 'popup-reviews';
popupContainer.style.cssText = 'position: fixed; bottom: 20px; left: 20px; z-index: 9999; max-width: 320px;';
document.body.appendChild(popupContainer);

let currentReview = 0;
function showPopupReview() {
    const container = document.getElementById('popup-reviews');
    // Clear any existing popup
    container.innerHTML = '';
    
    const review = reviews[currentReview];
    
    const popup = document.createElement('div');
    popup.style.cssText = 'background: white; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); padding: 16px; border: 1px solid #f3f4f6; animation: slideInUp 0.5s ease-out;';
    popup.innerHTML = `
        <div style="display: flex; align-items: flex-start; gap: 12px;">
            <img src="${review.img}" alt="${review.name}" style="width: 48px; height: 48px; border-radius: 50%; object-fit: cover; border: 2px solid #fed7aa;">
            <div style="flex: 1;">
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 4px;">
                    <span style="font-weight: 600; color: #1f2937;">${review.name}</span>
                    <span style="font-size: 12px; color: #9ca3af;">${review.location}</span>
                </div>
                <div style="color: #facc15; font-size: 14px; margin-bottom: 4px;">${'★'.repeat(review.rating)}</div>
                <p style="color: #4b5563; font-size: 14px; margin: 0;">"${review.text}"</p>
                <p style="font-size: 12px; color: #9ca3af; margin-top: 4px;">✓ Verified • ${review.time}</p>
            </div>
            <button onclick="document.getElementById('popup-reviews').innerHTML=''" style="color: #9ca3af; cursor: pointer; background: none; border: none; font-size: 18px; padding: 0;">✕</button>
        </div>
    `;
    
    container.appendChild(popup);
    
    // Remove after 5 seconds
    setTimeout(() => {
        container.innerHTML = '';
    }, 5000);
    
    currentReview = (currentReview + 1) % reviews.length;
}

// Show first popup after 3 seconds, then every 8 seconds
setTimeout(showPopupReview, 3000);
setInterval(showPopupReview, 8000);
</script>
{% endblock %}

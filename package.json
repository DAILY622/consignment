{
  "name": "consignment-delivery",
  "version": "1.0.0",
  "description": "DailyFX Delivery - Consignment & Delivery Tracking System",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "d1:create": "wrangler d1 create consignment-delivery-db",
    "d1:migrate": "wrangler d1 migrations apply consignment-delivery-db",
    "d1:seed": "wrangler d1 execute consignment-delivery-db --command 'SELECT 1'",
    "setup": "npm run d1:create && wrangler secret put SECRET_KEY"
  },
  "devDependencies": {
    "wrangler": "^3.80.0"
  }
}

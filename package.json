{
  "name": "consignment-delivery",
  "version": "1.0.0",
  "description": "DailyFX Delivery - Full Cloudflare Stack",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --config wrangler-full.toml",
    "deploy": "wrangler deploy --config wrangler-full.toml",
    "tail": "wrangler tail --config wrangler-full.toml",
    "build": "tsc && esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231025.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.0.0",
    "wrangler": "^3.80.0"
  },
  "dependencies": {}
}

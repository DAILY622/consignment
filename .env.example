# DailyFX Delivery Logistics - Environment Variables
# Copy this file to .env and fill in your actual values

# Django Configuration
DEBUG=True
SECRET_KEY=your-secret-key-here-generate-with-python-secrets

# Database (local development uses SQLite by default)
# DATABASE_URL=postgresql://user:password@localhost:5432/consignment

# Email Configuration (optional for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@dailyfxdelivery.com
CONTACT_EMAIL=support@dailyfxdelivery.com

# Additional Settings
DJANGO_LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1

# Cloudflare R2 Configuration (for persistent media storage)
USE_R2=False
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_CUSTOM_DOMAIN=  # Optional: your custom domain for R2 bucket

# Production Settings (set these in your hosting platform)
# DEBUG=False
# SECRET_KEY=<generate-secure-key>
# DATABASE_URL=<your-postgres-url>
# ALLOWED_HOSTS=.onrender.com,.herokuapp.com,.railway.app
